{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "ignoreDeps": [
    "react",
    "react-dom",
    "@types/react",
    "@types/react-dom",
    "@types/react-test-renderer",
    "react-test-renderer"
  ],
  "extends": ["customManagers:biomeVersions"],
  "packageRules": [
    {
      "postUpgradeTasks": {
        "commands": ["npm run test -- -u"],
        "fileFilters": ["**/*.snap"],
        "executionMode": "branch"
      },
      "matchPackageNames": ["/^@fortawesome//"]
    }
  ]
}
